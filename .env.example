# Development Environment Variables

# Database (Supabase - Free tier recommended)
# Transaction mode pooler for queries (port 6543 with pgbouncer=true)
DATABASE_URL="postgresql://user:password@host:6543/postgres?pgbouncer=true"
# Session mode pooler for migrations (port 5432)
DIRECT_URL="postgresql://user:password@host:5432/postgres"

# NextAuth
NEXTAUTH_URL="http://localhost:3004"
NEXTAUTH_SECRET="development-secret-change-in-production"

# OpenAI for AI Agents (get from platform.openai.com/api-keys)
OPENAI_API_KEY="sk-proj-your-openai-api-key"

# App Config
APP_URL="http://localhost:3004"
APP_NAME="BlocHub"

# Stripe (get from stripe.com/dashboard) - for tenant payments
STRIPE_SECRET_KEY="sk_test_your-stripe-secret-key"
STRIPE_WEBHOOK_SECRET="whsec_your-webhook-secret"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_your-stripe-publishable-key"

# Revolut Merchant API (for subscription payments)
# Get from Revolut Business -> Merchant API
REVOLUT_API_KEY="sk_xxx-your-revolut-api-key"
REVOLUT_WEBHOOK_SECRET="whsec_xxx-your-webhook-secret"
REVOLUT_ENVIRONMENT="sandbox" # sandbox or production

# BlocHub Company Details (for invoices)
BLOCHUB_CUI="RO00000000"
BLOCHUB_ADRESA="București, România"
BLOCHUB_IBAN="RO00XXXX0000000000000000"
BLOCHUB_BANCA="Banca Transilvania"

# Cron Jobs Secret (generate with: openssl rand -base64 32)
CRON_SECRET="your-cron-secret-key-change-this"

# ANAF SPV Integration (optional, for Romanian e-Factura)
# Get credentials from ANAF SPV portal: https://www.anaf.ro/anaf/internet/ANAF/despre_anaf/strategii_anaf/proiecte_digitalizare/spv
# ANAF_SPV_CLIENT_ID="your-spv-client-id"
# ANAF_SPV_CLIENT_SECRET="your-spv-client-secret"
# ANAF_SPV_REDIRECT_URI="https://your-domain.com/api/spv/callback"
# ANAF_SPV_API_URL="https://api.anaf.ro/prod/FCTEL/rest"

# OCR Service (optional, for invoice scanning)
# OCR_SERVICE_URL="http://localhost:8000"

# Email Service - Resend (optional, for notifications)
# RESEND_API_KEY="re_your-resend-api-key"

# Sentry (optional, for error tracking)
# NEXT_PUBLIC_SENTRY_DSN="your-sentry-dsn"

# Analytics - Google Analytics 4 (optional)
# NEXT_PUBLIC_GA_MEASUREMENT_ID="G-XXXXXXXXXX"

# Google Site Verification (optional, for Search Console)
# GOOGLE_SITE_VERIFICATION="your-verification-code"

# Public App URL (for SEO, OG tags)
NEXT_PUBLIC_APP_URL="http://localhost:3004"
